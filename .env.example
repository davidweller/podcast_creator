# Anthropic Claude API Key
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Google Gemini API Key (for image generation on the Images tab)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Europeana API Key (for Real Images tab - historical archive search)
# Register for free at https://pro.europeana.eu/page/get-api
# Note: Library of Congress and Wikimedia Commons APIs do not require keys
EUROPEANA_API_KEY=your_europeana_api_key_here
